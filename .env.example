# ─────────────────────────────────────────────
# Cartora Client — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# Only NEXT_PUBLIC_* values are exposed to the browser.
# ─────────────────────────────────────────────

# Base URL of the Cartora API (versioned)
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Stripe publishable key (used from Step 11)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Public site URL (used for metadata/SEO)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
